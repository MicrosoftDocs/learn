@startuml
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 16
left to right direction

skinparam rectangle {
  FontSize 16
  BorderThickness 2
  RoundCorner 8
}

skinparam arrow {
  Color #444444
  FontSize 15
  FontColor #000000
  Thickness 2
}

skinparam note {
  BackgroundColor #FFF4E5
  FontColor #000000
  BorderColor #FF5C39
  FontSize 15
}

skinparam legend {
  BackgroundColor #FFFFFF
  BorderColor #CCCCCC
  FontSize 15
}

legend top right
  |= Color |= Role |
  |<#0078D4>   | Component enabled — protection active |
  |<#F4364C>   | Component disabled — protection lost |
end legend

rectangle "**Secure Boot**\n\nSignature enforcement\nat firmware level" as SB #0078D4 {
}

rectangle "**vTPM**\n\nBoot chain\nmeasurement" as vTPM #0078D4 {
}

rectangle "**Integrity Monitoring**\n\nAttestation and\nDefender for Cloud alerts" as IM #0078D4 {
}

rectangle "**Secure Boot OFF**\n\nSignatures not checked\nvTPM still records\nwhat actually ran" as SB_off #F4364C {
}

rectangle "**vTPM OFF**\n\nNo boot measurements\nIntegrity Monitoring\ncannot function" as vTPM_off #F4364C {
}

rectangle "**Integrity Monitoring OFF**\n\nvTPM still measures locally\nNo alerts reach\nDefender for Cloud" as IM_off #F4364C {
}

SB --> SB_off : disable
vTPM --> vTPM_off : disable
IM --> IM_off : disable

vTPM_off --> IM_off : also disables

note bottom of vTPM_off
  Only dependency —
  all other components
  operate independently
end note

@enduml
